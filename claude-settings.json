{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(find)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git revert:*)",
      "Bash(git cherry-pick:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "dark",
  "effort": "high",
  "tui": "fullscreen",
  "preferredNotifChannel": "terminal_bell",
  "autoMemoryEnabled": false
}
