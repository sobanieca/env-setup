{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(find)"
    ]
  },
  "model": "opus[1m]",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "theme": "dark",
  "effort": "high",
  "tui": "fullscreen",
  "preferredNotifChannel": "terminal_bell",
  "autoMemoryEnabled": false
}
