#!/bin/bash

PREV_CPU_TOTAL=0
PREV_CPU_IDLE=0
declare -a PREV_CORE_TOTAL
declare -a PREV_CORE_IDLE
CPU=0
CPU_MAX=0

GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
RESET='\033[0m'

WATCH=false
TMUX_MODE=false

for arg in "$@"; do
    case "$arg" in
        -w|--watch) WATCH=true ;;
        --no-color) GREEN=''; YELLOW=''; RED=''; RESET='' ;;
        --tmux) TMUX_MODE=true; GREEN='#[fg=#00ffd2]'; YELLOW='#[fg=#e0af68]'; RED='#[fg=#ff4499]'; RESET='#[fg=#7aa2f7]' ;;
        -h|--help)
            echo "Usage: usage [OPTIONS]"
            echo ""
            echo "Display current CPU, memory, and disk usage."
            echo ""
            echo "Options:"
            echo "  -w, --watch     Refresh stats every second"
            echo "  --no-color      Disable colored output"
            echo "  --tmux          Output with tmux-compatible color codes"
            echo "  -h, --help      Show this help message"
            exit 0
            ;;
    esac
done

update_cpu() {
    local max=0
    local i=0
    local label user nice system idle iowait irq softirq steal
    while read -r label user nice system idle iowait irq softirq steal _; do
        case "$label" in
            cpu|cpu[0-9]*) ;;
            *) break ;;
        esac
        local total=$((user + nice + system + idle + iowait + irq + softirq + steal))
        local total_idle=$((idle + iowait))
        if [[ "$label" == "cpu" ]]; then
            local diff_total=$((total - PREV_CPU_TOTAL))
            local diff_idle=$((total_idle - PREV_CPU_IDLE))
            PREV_CPU_TOTAL=$total
            PREV_CPU_IDLE=$total_idle
            if [[ $diff_total -gt 0 ]]; then
                CPU=$(( (diff_total - diff_idle) * 100 / diff_total ))
            else
                CPU=0
            fi
        else
            local prev_total=${PREV_CORE_TOTAL[$i]:-0}
            local prev_idle=${PREV_CORE_IDLE[$i]:-0}
            local diff_total=$((total - prev_total))
            local diff_idle=$((total_idle - prev_idle))
            PREV_CORE_TOTAL[$i]=$total
            PREV_CORE_IDLE[$i]=$total_idle
            local pct=0
            if [[ $diff_total -gt 0 ]]; then
                pct=$(( (diff_total - diff_idle) * 100 / diff_total ))
            fi
            (( pct > max )) && max=$pct
            i=$((i + 1))
        fi
    done < /proc/stat
    CPU_MAX=$max
}

color_for() {
    local pct=$1
    if [[ $pct -ge 95 ]]; then
        printf '%s' "$RED"
    elif [[ $pct -ge 80 ]]; then
        printf '%s' "$YELLOW"
    else
        printf '%s' "$GREEN"
    fi
}

show_stats() {
    update_cpu
    read -r MEM_USED MEM_TOTAL MEM_PCT < <(free -m | awk '/Mem:/ {printf "%.2f %.2f %d\n", $3/1024, $2/1024, $3/$2*100}')
    read -r DISK_USED DISK_TOTAL DISK_PCT < <(df -BG / | awk 'NR==2 {gsub("G","",$3); gsub("G","",$2); printf "%d %d %d\n", $3, $2, $3/$2*100}')

    if $TMUX_MODE; then
        printf "CPU:$(color_for $CPU)${CPU}%%${RESET} ($(color_for $CPU_MAX)${CPU_MAX}%%${RESET}) MEM:$(color_for $MEM_PCT)${MEM_USED}/${MEM_TOTAL}GB${RESET} DISK:$(color_for $DISK_PCT)${DISK_USED}/${DISK_TOTAL}GB${RESET}"
    else
        printf "CPU: $(color_for $CPU)${CPU}%%${RESET} ($(color_for $CPU_MAX)${CPU_MAX}%%${RESET}), MEMORY: $(color_for $MEM_PCT)${MEM_USED}GB/${MEM_TOTAL}GB${RESET}, DISK: $(color_for $DISK_PCT)${DISK_USED}GB/${DISK_TOTAL}GB${RESET}\033[K\r"
    fi
}

if $WATCH; then
    update_cpu
    sleep 1
    while true; do
        show_stats
        sleep 1
    done
else
    update_cpu
    sleep 0.5
    show_stats
    if ! $TMUX_MODE; then
        echo  # print newline for single run
    fi
fi
