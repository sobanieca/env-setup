#!/bin/bash
# Prints the current git worktree name for the tmux status bar.
# Only prints when the pane is inside a *linked* worktree (git worktree add),
# so the main checkout stays uncluttered. Pass the pane path as $1.

path="${1:-$PWD}"

git_dir=$(git -C "$path" rev-parse --git-dir 2>/dev/null) || exit 0
common_dir=$(git -C "$path" rev-parse --git-common-dir 2>/dev/null) || exit 0

# In the main worktree these are equal; in a linked worktree they differ.
[ "$git_dir" = "$common_dir" ] && exit 0

toplevel=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null) || exit 0
printf '⑃ %s' "$(basename "$toplevel")"
