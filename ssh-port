#!/usr/bin/env bash
#
# ssh-port — add port forwards to existing SSH connections (ControlMaster)
#
# Runs on the client machine (the one initiating SSH), not on the server.
#
# Usage:
#   ssh-port                      List active SSH connections with indexes
#   ssh-port -p PORT [TARGET]     Add tunnel PORT -> TARGET:PORT to the
#   ssh-port --port PORT [TARGET] existing connection (ssh -O forward)
#   ssh-port -c PORT [TARGET]     Cancel a previously added tunnel
#
# TARGET can be:
#   - an index from the connection list (e.g. 1, 2, ...)
#   - a hostname / user@host
#   - omitted: if exactly one active connection exists, it is used;
#     otherwise the list is shown and you must pick one.
#
# Requires ControlMaster in ~/.ssh/config:
#   Host *
#       ControlMaster auto
#       ControlPath ~/.ssh/sockets/cm-%r@%h:%p
#       ControlPersist 10m

set -euo pipefail

usage() {
    awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
    exit "${1:-0}"
}

# Extract the destination (user@host or host) from an ssh command line.
parse_ssh_target() {
    local args_with_value="BbcDEeFIiJLlmOopQRSWw"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --) shift; break ;;
            -[$args_with_value])  shift 2 || return 1; continue ;;
            -[$args_with_value]*) shift; continue ;;
            -*)                   shift; continue ;;
            *)  printf '%s\n' "$1"; return 0 ;;
        esac
    done
    return 1
}

# One active outgoing ssh destination per line (deduplicated, stable order).
get_hosts() {
    local pid cmd rest target
    local seen=""
    while read -r pid cmd rest; do
        [[ -n "${rest:-}" ]] || continue
        # shellcheck disable=SC2086
        target=$(eval parse_ssh_target $rest 2>/dev/null) || continue
        [[ -n "$target" ]] || continue
        case " $seen " in *" $target "*) continue ;; esac
        seen="$seen $target"
        printf '%s\n' "$target"
    done < <(pgrep -a -x ssh 2>/dev/null || true)
}

has_master() {
    ssh -O check "$1" >/dev/null 2>&1
}

print_indexed() {
    local i=1 host mark
    while IFS= read -r host; do
        if has_master "$host"; then mark="[master]"; else mark="[no master]"; fi
        printf '  %d - %-50s %s\n' "$i" "$host" "$mark"
        i=$((i + 1))
    done
}

list_connections() {
    local hosts
    hosts=$(get_hosts)

    echo "=== Active outgoing SSH connections ==="
    if [[ -n "$hosts" ]]; then
        print_indexed <<< "$hosts"
        echo
        echo "Tunnels can be added to [master] connections: $(basename "$0") -p PORT <index>"
    else
        echo "  (none)"
    fi
}

# Resolve TARGET (index, hostname, or empty) to a host.
resolve_target() {
    local target="${1:-}"
    local hosts count
    hosts=$(get_hosts)
    count=0
    [[ -n "$hosts" ]] && count=$(wc -l <<< "$hosts")

    if [[ -z "$target" ]]; then
        if (( count == 1 )); then
            printf '%s\n' "$hosts"
            return 0
        elif (( count == 0 )); then
            echo "Error: no active SSH connections found and no host given." >&2
            exit 1
        else
            echo "Error: there are $count active connections. Which one to choose?" >&2
            print_indexed <<< "$hosts" >&2
            echo "Re-run with an index or hostname: $(basename "$0") -p PORT <index|host>" >&2
            exit 1
        fi
    fi

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        if (( target >= 1 && target <= count )); then
            sed -n "${target}p" <<< "$hosts"
            return 0
        fi
        echo "Error: index '$target' out of range (there are $count active connections):" >&2
        [[ -n "$hosts" ]] && print_indexed <<< "$hosts" >&2
        exit 1
    fi

    # Hostname literal: prefer the matching active connection (keeps user@).
    if [[ -n "$hosts" ]]; then
        local t
        while IFS= read -r t; do
            if [[ "$t" == "$target" || "${t#*@}" == "$target" ]]; then
                printf '%s\n' "$t"
                return 0
            fi
        done <<< "$hosts"
    fi
    printf '%s\n' "$target"
}

require_master() {
    local host="$1"
    if ! has_master "$host"; then
        echo "Error: no ControlMaster connection for '$host'." >&2
        echo >&2
        echo "This tool adds tunnels to existing connections and needs ControlMaster." >&2
        echo "Make sure ~/.ssh/config contains:" >&2
        echo "    Host *" >&2
        echo "        ControlMaster auto" >&2
        echo "        ControlPath ~/.ssh/sockets/cm-%r@%h:%p" >&2
        echo "        ControlPersist 10m" >&2
        echo "then reconnect to '$host' and try again." >&2
        exit 1
    fi
}

validate_port() {
    if ! [[ "$1" =~ ^[0-9]+$ ]] || (( $1 < 1 || $1 > 65535 )); then
        echo "Error: '$1' is not a valid port number (1-65535)." >&2
        exit 1
    fi
}

open_tunnel() {
    local port="$1" host="$2"
    validate_port "$port"

    if { ss -tln 2>/dev/null || true; } | awk '{print $4}' | grep -qE "[:.]${port}\$"; then
        echo "Error: local port $port is already in use." >&2
        exit 1
    fi

    require_master "$host"
    ssh -O forward -L "${port}:localhost:${port}" "$host"
    echo "Tunnel active: localhost:${port} -> ${host}:${port}"
    echo "Remove it with: $(basename "$0") -c ${port} ${host}"
}

cancel_tunnel() {
    local port="$1" host="$2"
    validate_port "$port"
    require_master "$host"
    ssh -O cancel -L "${port}:localhost:${port}" "$host"
    echo "Tunnel removed: localhost:${port} -> ${host}:${port}"
}

# ---------------- argument parsing ----------------
PORT=""
CANCEL_PORT=""
TARGET=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage 0
            ;;
        -p|--port)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires a port number." >&2; exit 1; }
            PORT="$2"
            shift 2
            ;;
        --port=*)
            PORT="${1#*=}"
            shift
            ;;
        -c|--cancel)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires a port number." >&2; exit 1; }
            CANCEL_PORT="$2"
            shift 2
            ;;
        --cancel=*)
            CANCEL_PORT="${1#*=}"
            shift
            ;;
        -*)
            echo "Error: unknown option '$1'." >&2
            usage 1
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

if [[ -n "$PORT" && -n "$CANCEL_PORT" ]]; then
    echo "Error: -p and -c cannot be combined." >&2
    exit 1
elif [[ -n "$PORT" ]]; then
    HOST=$(resolve_target "$TARGET")
    open_tunnel "$PORT" "$HOST"
elif [[ -n "$CANCEL_PORT" ]]; then
    HOST=$(resolve_target "$TARGET")
    cancel_tunnel "$CANCEL_PORT" "$HOST"
else
    list_connections
fi
