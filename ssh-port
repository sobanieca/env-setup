#!/usr/bin/env bash
#
# ssh-port — add port forwards to a running SSH session
#
# Runs on the client machine (the one initiating SSH), not on the server.
#
# Usage:
#   ssh-port                      List active SSH connections with indexes
#   ssh-port -p PORT [TARGET]     Open tunnel PORT -> TARGET:PORT
#   ssh-port --port PORT [TARGET]
#   ssh-port -c PORT [TARGET]     Close a tunnel opened earlier
#   ssh-port -n, --dry-run        Print the ssh command instead of running it
#
# TARGET can be:
#   - an index from the connection list (e.g. 1, 2, ...)
#   - a hostname / user@host
#   - omitted: if exactly one active connection exists, it is used;
#     otherwise the list is shown and you must pick one.
#
# The connection flags of the already running ssh process (-i, -l, -p, -o ...)
# are read from /proc and reused to start a second, background connection:
#
#   ssh <same flags> -f -N -L PORT:localhost:PORT TARGET
#
# So no ControlMaster / ~/.ssh/config setup is needed. Two caveats follow from
# it being a real second connection:
#   - the server authenticates it again, so key auth must work unattended
#     (a passphrase-protected key without ssh-agent will prompt)
#   - it counts as another login, so a 'maxsyslogins' / 'maxlogins' limit in
#     the server's /etc/security/limits.conf can reject it

set -euo pipefail

usage() {
    awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
    exit "${1:-0}"
}

US=$'\x1f' # separator used to keep argv intact across command substitution

# ssh options taking a separate value, split by whether the value describes the
# connection itself (reused) or the session/forwarding (dropped).
VAL_KEEP="BbcFIiJlmoPp"
VAL_DROP="DEeLOQRSWw"
VAL_ALL="$VAL_KEEP$VAL_DROP"
BOOL_KEEP="46ACq"

# Our own ssh processes, one per line: PID US arg US arg ...
ssh_procs() {
    local dir pid comm argv joined a
    for dir in /proc/[0-9]*; do
        pid=${dir#/proc/}
        [[ -O "$dir" ]] || continue # only our own processes
        read -r comm <"$dir/comm" 2>/dev/null || continue
        [[ $comm == ssh ]] || continue
        mapfile -d '' -t argv <"$dir/cmdline" 2>/dev/null || continue
        ((${#argv[@]} > 1)) || continue
        joined=""
        for a in "${argv[@]:1}"; do joined+="$US$a"; done
        printf '%s%s\n' "$pid" "$joined"
    done
}

# Parse an ssh argv (passed as "$@").
# Sets: P_TARGET, P_CONN (array, connection flags), P_FWD (array, -L specs),
#       P_NOSHELL (1 if -N, i.e. a tunnel we opened)
parse_argv() {
    P_TARGET=""
    P_CONN=()
    P_FWD=()
    P_NOSHELL=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --) shift; break ;;
            -[$VAL_ALL])
                [[ $# -ge 2 ]] || return 1
                case "$1" in
                    -L) P_FWD+=("$2") ;;
                    -[$VAL_KEEP]) P_CONN+=("$1" "$2") ;;
                esac
                shift 2
                ;;
            -[$VAL_ALL]*)
                case "$1" in
                    -L*) P_FWD+=("${1#-L}") ;;
                    -[$VAL_KEEP]*) P_CONN+=("$1") ;;
                esac
                shift
                ;;
            -*)
                [[ $1 == *N* ]] && P_NOSHELL=1
                # keep only harmless connection-level boolean flags
                [[ $1 =~ ^-[$BOOL_KEEP]+$ ]] && P_CONN+=("$1")
                shift
                ;;
            *)
                P_TARGET="$1"
                return 0 # anything after the target is a remote command
                ;;
        esac
    done
    [[ -n $P_TARGET ]]
}

# Read one ssh_procs line into P_PID + parsed fields.
parse_proc_line() {
    local line="$1" parts
    IFS="$US" read -r -a parts <<<"$line"
    P_PID="${parts[0]}"
    parse_argv "${parts[@]:1}" 2>/dev/null || return 1
    [[ -n $P_TARGET ]]
}

# Interactive sessions (not tunnels), deduplicated, stable order.
get_hosts() {
    local line seen=""
    while IFS= read -r line; do
        parse_proc_line "$line" || continue
        (( P_NOSHELL )) && continue
        case " $seen " in *" $P_TARGET "*) continue ;; esac
        seen="$seen $P_TARGET"
        printf '%s\n' "$P_TARGET"
    done < <(ssh_procs)
}

# Tunnels this tool opened: PID, target, forward spec.
get_tunnels() {
    local line f
    while IFS= read -r line; do
        parse_proc_line "$line" || continue
        (( P_NOSHELL )) || continue
        for f in "${P_FWD[@]:-}"; do
            [[ -n $f ]] && printf '%s\t%s\t%s\n' "$P_PID" "$P_TARGET" "$f"
        done
    done < <(ssh_procs)
}

# Hosts we can cancel a tunnel on: sessions first (so indexes match the list),
# then hosts that only have tunnels left (the session may already be closed).
get_all_hosts() {
    { get_hosts; get_tunnels | cut -f2; } | awk 'NF && !seen[$0]++'
}

# Connection flags of a running ssh process for a host (first match wins).
# Prefers an interactive session, falls back to a tunnel we opened earlier —
# both carry the same connection flags. Sets P_CONN; fails if neither exists.
conn_args_for() {
    local host="$1" want_tunnel line
    for want_tunnel in 0 1; do
        while IFS= read -r line; do
            parse_proc_line "$line" || continue
            (( P_NOSHELL == want_tunnel )) || continue
            [[ $P_TARGET == "$host" ]] && return 0
        done < <(ssh_procs)
    done
    return 1
}

print_indexed() {
    local i=1 host
    while IFS= read -r host; do
        printf '  %d - %s\n' "$i" "$host"
        i=$((i + 1))
    done
}

list_connections() {
    local hosts tunnels pid target fwd
    hosts=$(get_hosts)

    echo "=== Active outgoing SSH connections ==="
    if [[ -n "$hosts" ]]; then
        print_indexed <<<"$hosts"
        echo
        echo "Add a tunnel with: $(basename "$0") -p PORT <index>"
    else
        echo "  (none)"
    fi

    tunnels=$(get_tunnels)
    if [[ -n "$tunnels" ]]; then
        echo
        echo "=== Tunnels opened by $(basename "$0") ==="
        while IFS=$'\t' read -r pid target fwd; do
            printf '  %-24s -> %-24s (pid %s)\n' "$fwd" "$target" "$pid"
        done <<<"$tunnels"
    fi
}

# Resolve TARGET (index, hostname, or empty) to a host, picking from $2.
resolve_target() {
    local target="${1:-}"
    local hosts="${2:-}"
    local count
    count=0
    [[ -n "$hosts" ]] && count=$(wc -l <<<"$hosts")

    if [[ -z "$target" ]]; then
        if (( count == 1 )); then
            printf '%s\n' "$hosts"
            return 0
        elif (( count == 0 )); then
            echo "Error: no active SSH connections found and no host given." >&2
            exit 1
        else
            echo "Error: there are $count active connections. Which one to choose?" >&2
            print_indexed <<<"$hosts" >&2
            echo "Re-run with an index or hostname: $(basename "$0") -p PORT <index|host>" >&2
            exit 1
        fi
    fi

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        if (( target >= 1 && target <= count )); then
            sed -n "${target}p" <<<"$hosts"
            return 0
        fi
        echo "Error: index '$target' out of range (there are $count active connections):" >&2
        [[ -n "$hosts" ]] && print_indexed <<<"$hosts" >&2
        exit 1
    fi

    # Hostname literal: prefer the matching active connection (keeps user@).
    if [[ -n "$hosts" ]]; then
        local t
        while IFS= read -r t; do
            if [[ "$t" == "$target" || "${t#*@}" == "$target" ]]; then
                printf '%s\n' "$t"
                return 0
            fi
        done <<<"$hosts"
    fi
    printf '%s\n' "$target"
}

validate_port() {
    if ! [[ "$1" =~ ^[0-9]+$ ]] || (( $1 < 1 || $1 > 65535 )); then
        echo "Error: '$1' is not a valid port number (1-65535)." >&2
        exit 1
    fi
}

open_tunnel() {
    local port="$1" host="$2" spec

    if { ss -tln 2>/dev/null || true; } | awk '{print $4}' | grep -qE "[:.]${port}\$"; then
        echo "Error: local port $port is already in use." >&2
        exit 1
    fi

    if ! conn_args_for "$host"; then
        echo "Error: no active SSH connection to '$host' to copy settings from." >&2
        echo "Connect to it first — this tool reuses the flags of a running session." >&2
        exit 1
    fi

    spec="${port}:localhost:${port}"
    if (( DRY_RUN )); then
        printf 'ssh'
        printf ' %q' "${P_CONN[@]:-}" -f -N -L "$spec" "$host"
        printf '\n'
        return 0
    fi

    ssh "${P_CONN[@]:-}" -f -N -L "$spec" "$host"
    echo "Tunnel active: localhost:${port} -> ${host}:${port}"
    echo "Remove it with: $(basename "$0") -c ${port} ${host}"
}

cancel_tunnel() {
    local port="$1" host="$2" spec pid target fwd found=0
    spec="${port}:localhost:${port}"

    while IFS=$'\t' read -r pid target fwd; do
        [[ -n "$pid" ]] || continue
        [[ "$target" == "$host" && "$fwd" == "$spec" ]] || continue
        if (( DRY_RUN )); then
            echo "kill $pid  # $fwd -> $target"
        else
            kill "$pid"
            echo "Tunnel removed: localhost:${port} -> ${host}:${port} (pid $pid)"
        fi
        found=1
    done < <(get_tunnels)

    if (( ! found )); then
        echo "Error: no tunnel for port $port on '$host' found." >&2
        echo "Run '$(basename "$0")' to see tunnels that are currently open." >&2
        exit 1
    fi
}

# ---------------- argument parsing ----------------
PORT=""
CANCEL_PORT=""
TARGET=""
DRY_RUN=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage 0
            ;;
        -n|--dry-run)
            DRY_RUN=1
            shift
            ;;
        -p|--port)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires a port number." >&2; exit 1; }
            PORT="$2"
            shift 2
            ;;
        --port=*)
            PORT="${1#*=}"
            shift
            ;;
        -c|--cancel)
            [[ $# -ge 2 ]] || { echo "Error: $1 requires a port number." >&2; exit 1; }
            CANCEL_PORT="$2"
            shift 2
            ;;
        --cancel=*)
            CANCEL_PORT="${1#*=}"
            shift
            ;;
        -*)
            echo "Error: unknown option '$1'." >&2
            usage 1
            ;;
        *)
            TARGET="$1"
            shift
            ;;
    esac
done

if [[ -n "$PORT" && -n "$CANCEL_PORT" ]]; then
    echo "Error: -p and -c cannot be combined." >&2
    exit 1
elif [[ -n "$PORT" ]]; then
    validate_port "$PORT"
    HOST=$(resolve_target "$TARGET" "$(get_all_hosts)")
    open_tunnel "$PORT" "$HOST"
elif [[ -n "$CANCEL_PORT" ]]; then
    validate_port "$CANCEL_PORT"
    HOST=$(resolve_target "$TARGET" "$(get_all_hosts)")
    cancel_tunnel "$CANCEL_PORT" "$HOST"
else
    list_connections
fi
