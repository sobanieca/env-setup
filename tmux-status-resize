#!/bin/bash

PL_RIGHT=$'\uE0B0'
PL_LEFT=$'\uE0B2'
PL_LEFT_THIN=$'\uE0B3'

width=$(tmux display -p "#{client_width}")

CLAUDE_LEFT="#[fg=#7aa2f7,bg=#3b4261] #($HOME/.tmux/claude-usage-color short) #[fg=#3b4261,bg=#1f2335]${PL_RIGHT}"
USAGE_LEFT="#[fg=#7aa2f7,bg=#3b4261] #($HOME/tools/usage --tmux) #[fg=#3b4261,bg=#1f2335]${PL_RIGHT}"
USAGE_RIGHT="#[align=right]#[fg=#3b4261,bg=#1f2335]${PL_LEFT}#[fg=#7aa2f7,bg=#3b4261] #($HOME/tools/usage --tmux) "
# Wide mode: claude usage and cpu usage grouped in a single right-aligned pill (claude first).
CLAUDE_USAGE_RIGHT="#[align=right]#[fg=#3b4261,bg=#1f2335]${PL_LEFT}#[fg=#7aa2f7,bg=#3b4261] #($HOME/.tmux/claude-usage-color short) #[fg=#7aa2f7,bg=#3b4261]${PL_LEFT_THIN} #($HOME/tools/usage --tmux) "
GITMUX_DATE_RIGHT="#[align=right]#[fg=#3b4261,bg=#1f2335]${PL_LEFT}#[fg=#7aa2f7,bg=#3b4261] #(gitmux -cfg $HOME/.config/.gitmux.conf '#{pane_current_path}')#[fg=#7aa2f7,bg=#3b4261] ${PL_LEFT_THIN} %a %Y-%m-%d #[fg=#7aa2f7,bg=#3b4261]${PL_LEFT}#[fg=#1d202f,bg=#7aa2f7,bold] %H:%M "
GITMUX_DATE_LEFT="#[fg=#7aa2f7,bg=#3b4261] #(gitmux -cfg $HOME/.config/.gitmux.conf '#{pane_current_path}')#[fg=#7aa2f7,bg=#3b4261] ${PL_LEFT_THIN} %a %Y-%m-%d #[fg=#7aa2f7,bg=#3b4261]${PL_LEFT}#[fg=#1d202f,bg=#7aa2f7,bold] %H:%M #[fg=#7aa2f7,bg=#1f2335]${PL_RIGHT}"

if [ "$width" -lt 110 ]; then
    tmux set -g status 4
    tmux set -g status-format[1] "$GITMUX_DATE_LEFT"
    tmux set -g status-format[2] "$CLAUDE_LEFT"
    tmux set -g status-format[3] "$USAGE_LEFT"
else
    tmux set -g status 2
    tmux set -g status-format[1] "${GITMUX_DATE_LEFT}${CLAUDE_USAGE_RIGHT}"
fi
